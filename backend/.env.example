# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# ─── Telegram ─────────────────────────────────────────────────────────────────
# BotFather'dan al: /newbot komutu ile
TELEGRAM_BOT_TOKEN=
# Telegram'da @userinfobot'a mesaj at, sana chat_id söyler
TELEGRAM_OWNER_CHAT_ID=6026020872

# ─── Meta Graph API (Instagram) ───────────────────────────────────────────────
# https://developers.facebook.com/apps/ → yeni app oluştur
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# ─── SerpAPI (Rakip & Trend Analizi) ─────────────────────────────────────────
# https://serpapi.com/ → ücretsiz 100 arama/ay
SERPAPI_KEY=

# ─── App Config ───────────────────────────────────────────────────────────────
# Varsayılan tenant (tek oteli temsil eder, multi-tenant için genişletilebilir)
DEFAULT_TENANT_ID=hotel_001
DATABASE_URL=sqlite:///./social_media_agent.db
CHROMA_PERSIST_DIR=./chroma_db
FRONTEND_URL=http://localhost:5173
